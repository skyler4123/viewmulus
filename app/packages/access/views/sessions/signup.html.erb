<% if notice.present? %>
  <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
<% end %>
<%= render(Form::SessionComponent.new(url: signup_path, method: :post, class: "flex flex-col justify-center items-center gap-y-5")) do %>
  <div class="font-bold text-lg text-gray-900">Sign Up!</div>
  <%= render(Input::TextComponent.new(label: "Email", name: "user[email]", placeholder: "example@gmail.com", type: "email")) %>
  <%= render(Input::PasswordComponent.new(name: "user[password]")) %>
  <%= render(Input::PasswordConfirmationComponent.new(name: "user[password_confirmation]")) %>
  <%= render(Input::SubmitComponent.new(label: "Sign Up")) %>
  <nav class="text-sm">
    Don't have an account? <%= link_to("Sign In", signin_path, class: "text-blue-600") %>
  </nav>
<% end %>

