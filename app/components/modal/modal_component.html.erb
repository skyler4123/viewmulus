<dialog data-controller="modal--modal-component" data-modal--modal-component-target="modal" class='fixed h-screen w-screen inset-0 z-10 flex flex-col items-center justify-center bg-transparent hidden'>
  <div class="h-screen w-screen bg-slate-500 cursor-pointer opacity-25" data-action="click->modal--modal-component#exit">
  </div>
  <div class="absolute opacity-100">
    <%= content %>
  </div>
</dialog>